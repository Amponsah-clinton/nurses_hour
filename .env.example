# Supabase — for app data/storage (Django uses SQLite for sessions, auth).
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# DataHub Ghana — data bundle delivery & wallet top-up
DATAHUB_API_KEY=
DATAHUB_BASE_URL=https://app.datahubgh.com/api/external
DATAHUB_TOPUP_URL=https://app.datahubgh.com
DATAHUB_BUNDLES_URL=
DATAHUB_BUNDLES_BASE=https://app.datahubgh.com/api

# Optional: dashboard API access via Authorization: Bearer <secret>
DASHBOARD_API_SECRET=

# Email (optional, for contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Django
SECRET_KEY=your-secret-key
DEBUG=True
