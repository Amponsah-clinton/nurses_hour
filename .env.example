# Supabase — Django uses Postgres (Supabase DB); REST/storage use these keys.
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Django database = Supabase Postgres (required on Vercel; optional locally).
# Option A — individual vars (recommended if password has @ or special chars):
DB_HOST=aws-0-REGION.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your-database-password

# Option B — single URL (encode @ in password as %40):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Email (optional, for contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
